    </div>

    <!-- Portfolio -->
    <div id="portfolio" class="max-w-6xl mx-auto px-6 py-16 border-t border-purple-900/40">
        <h2 class="section-header mb-2 vikings-purple">Portfolio Overview</h2>
        <div class="text-emerald-400 mb-8">$275,947 Total • From your Google Sheet</div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-zinc-900 border border-purple-900/30 p-6 rounded-3xl">
                <div class="text-sm text-zinc-400">Today's Change</div>
                <div class="text-2xl font-semibold text-red-400">-$3,531 (-1.28%)</div>
            </div>
            <div class="bg-zinc-900 border border-purple-900/30 p-6 rounded-3xl">
                <div class="text-sm text-zinc-400">Unrealized Gain/Loss</div>
                <div class="text-2xl font-semibold text-emerald-400">$70,523 (26.36%)</div>
            </div>
            <div class="bg-zinc-900 border border-purple-900/30 p-6 rounded-3xl">
