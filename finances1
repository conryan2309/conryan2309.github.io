            <button onclick="toggleDarkMode()" 
                    class="flex items-center justify-center w-11 h-11 rounded-3xl border border-purple-800 hover:bg-purple-900/40 transition-all text-purple-300 hover:text-yellow-400">
                <i class="fa-solid fa-moon text-xl" id="theme-icon"></i>
            </button>
        </div>
    </nav>

    <!-- Hero -->
    <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
