                <div class="text-2xl font-semibold">$46,500 (48.95% to goal)</div>
            </div>
            <div class="bg-zinc-900 border border-purple-900/30 p-6 rounded-3xl">
                <div class="text-sm text-zinc-400">EoY Scenarios</div>
                <div class="text-xs">Bear: -5% • Base: 7% • Bull: 20%</div>
            </div>
        </div>
        
        <h3 class="font-semibold mb-4 vikings-purple">Current Holdings</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left border-b border-purple-900/30 text-zinc-400">
                        <th class="py-3">Symbol</th>
                        <th class="py-3">Shares</th>
                        <th class="py-3 text-right">Total Value</th>
                        <th class="py-3 text-right">% of Portfolio</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-purple-900/20">
                    <tr>
                        <td class="py-3 font-mono">TSLA</td>
                        <td class="py-3">625</td>
                        <td class="py-3 text-right">$254,850</td>
                        <td class="py-3 text-right text-emerald-400">89.0%</td>
                    </tr>
                    <tr>
                        <td class="py-3 font-mono">Space X</td>
                        <td class="py-3">145.2</td>
                        <td class="py-3 text-right">$21,097</td>
                        <td class="py-3 text-right">11.0%</td>
                    </tr>
                    <tr>
                        <td class="py-3 font-mono">VOO (401k)</td>
                        <td class="py-3">62.86</td>
                        <td class="py-3 text-right">$43,616</td>
                        <td class="py-3 text-right">—</td>
                    </tr>
                    <tr>
                        <td class="py-3 font-mono">QQQ (401k)</td>
                        <td class="py-3">25.51</td>
                        <td class="py-3 text-right">$18,508</td>
