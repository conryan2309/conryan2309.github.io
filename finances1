                </tbody>
            </table>
        </div>
    </div>

    <!-- Vehicles -->
    <div id="vehicles" class="max-w-6xl mx-auto px-6 py-16 border-t border-purple-900/40">
        <h2 class="section-header mb-8 vikings-purple">Vehicle Transition Plan</h2>
        <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-zinc-900 border border-purple-900/30 rounded-3xl p-8">
                <h3 class="font-semibold mb-4">Current Fleet</h3>
                <div>BMW 320i (high mileage) • Hyundai Elantra</div>
            </div>
            <div class="bg-zinc-900 border border-yellow-400/30 rounded-3xl p-8">
                <h3 class="font-semibold mb-4 text-yellow-400">Next Steps</h3>
                <div>Model Y 7-Seater (priority, low-APR) • Cybertruck later</div>
            </div>
        </div>
    </div>

    <!-- Goals -->
    <div id="goals" class="max-w-6xl mx-auto px-6 py-16 border-t border-purple-900/40">
        <h2 class="section-header mb-8 vikings-purple">Retirement Projections</h2>
        <div class="bg-zinc-900 border border-purple-900/30 p-8 rounded-3xl">
            <div class="text-emerald-400">Strong trajectory toward 2036 goals</div>
            <div class="mt-2">2036 Total (Base): ~$21.95M • Bull: ~$35.15M</div>
